# Polymarket wallet
PRIVATE_KEY=0x...
FUNDER_ADDRESS=0x...

# Polymarket CLOB API credentials
CLOB_API_KEY=...
CLOB_SECRET=...
CLOB_PASSPHRASE=...

# OpenRouter API key (get one at openrouter.ai)
OPENROUTER_API_KEY=sk-or-v1-...

# Telegram notifications (optional)
TELEGRAM_TOKEN=...
TELEGRAM_CHAT=...

# Trading config
ARMED=false              # set true to place real orders
RISK_LEVEL=MEDIUM        # LOW=85%, MEDIUM=70%, HIGH=55% AI confidence threshold
MAX_POSITIONS=4          # max open positions per strategy
MAX_BET=3.00             # max $ per trade
MIN_LIQUIDITY=500        # min $ liquidity to consider a market
